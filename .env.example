# Shared
NODE_ENV=development
WEB_ORIGIN=http://localhost:3000
WEB_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_ORIGIN=http://localhost:4000

# API
API_PORT=4000
DATABASE_URL="file:./dev.db"
SESSION_COOKIE_NAME=mfs_session
SESSION_TTL_DAYS=30
SESSION_SECRET=change_me_very_long_secret
CSRF_SECRET=change_me_csrf_secret
UPLOADS_DIR=./uploads
MAX_IMAGE_SIZE_MB=10
INVITE_DEFAULT_COMMUNITY_ID=
PUBLIC_BASE_URL=http://localhost:4000
OTP_SECRET=change_me_otp_secret
OTP_TTL_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=45
OTP_MAX_ATTEMPTS=5
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXT_PUBLIC_ENABLE_DEV_GUEST_TOKEN=true
